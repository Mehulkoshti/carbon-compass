# Copy this file to .env.local and fill in your key.
# Get a free Gemini API key at https://aistudio.google.com/apikey
# NOTE: .env.local is gitignored — your real key is never committed.

GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-2.5-flash

# Optional: your production URL, used for absolute social-share (OG) image links.
# On Vercel this is auto-detected; set it explicitly for a custom domain.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
